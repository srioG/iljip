<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 라이트 테마 팔레트 ===== -->
    <!-- 창/표면 -->
    <SolidColorBrush x:Key="WindowBgBrush"    Color="#F7F8FA" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="ToolbarBgBrush"   Color="#FFFFFF" />
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#F0F2F5" />
    <SolidColorBrush x:Key="BorderBrush"      Color="#E2E5E9" />

    <!-- 텍스트/아이콘 -->
    <SolidColorBrush x:Key="FgBrush"      Color="#1F2328" />
    <SolidColorBrush x:Key="FgMutedBrush" Color="#6B7280" />

    <!-- 강조색 -->
    <SolidColorBrush x:Key="AccentBrush"       Color="#2563EB" />
    <SolidColorBrush x:Key="AccentFgBrush"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryBrush"      Color="#2563EB" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />

    <!-- 상호작용 -->
    <SolidColorBrush x:Key="HoverBrush"   Color="#EEF2FF" />
    <SolidColorBrush x:Key="PressedBrush" Color="#DCE3FF" />

    <!-- 목록 -->
    <SolidColorBrush x:Key="RowAltBrush"    Color="#F4F6F8" />
    <SolidColorBrush x:Key="GridLineBrush"  Color="#ECEEF1" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#DCE7FF" />

</ResourceDictionary>
