<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 다크 테마 팔레트 ===== -->
    <!-- 창/표면 -->
    <SolidColorBrush x:Key="WindowBgBrush"    Color="#1A1C20" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#23262B" />
    <SolidColorBrush x:Key="ToolbarBgBrush"   Color="#23262B" />
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#202327" />
    <SolidColorBrush x:Key="BorderBrush"      Color="#33373E" />

    <!-- 텍스트/아이콘 -->
    <SolidColorBrush x:Key="FgBrush"      Color="#E8EAED" />
    <SolidColorBrush x:Key="FgMutedBrush" Color="#9AA1AB" />

    <!-- 강조색 -->
    <SolidColorBrush x:Key="AccentBrush"       Color="#4C9DF5" />
    <SolidColorBrush x:Key="AccentFgBrush"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryBrush"      Color="#3B82F6" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#2D6FE0" />

    <!-- 상호작용 -->
    <SolidColorBrush x:Key="HoverBrush"   Color="#2B2F36" />
    <SolidColorBrush x:Key="PressedBrush" Color="#343A43" />

    <!-- 목록 -->
    <SolidColorBrush x:Key="RowAltBrush"    Color="#1F2226" />
    <SolidColorBrush x:Key="GridLineBrush"  Color="#2C3036" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#2F3E57" />

</ResourceDictionary>
