<Window x:Class="Iljip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Iljip.ViewModels"
        xmlns:conv="clr-namespace:Iljip.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="620" Width="940"
        MinHeight="440" MinWidth="680"
        Background="{DynamicResource WindowBgBrush}"
        TextElement.Foreground="{DynamicResource FgBrush}"
        TextElement.FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        AllowDrop="True"
        PreviewDragOver="Window_DragOver"
        PreviewDrop="Window_Drop">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 툴바 -->
            <RowDefinition Height="*" />    <!-- 본문 -->
            <RowDefinition Height="Auto" /> <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ===== 툴바 ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="8,7">
                <!-- 좌측: 주요 동작 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}" ToolTip="압축 파일 열기 (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconOpen}" Style="{StaticResource ToolIcon}" />
                            <TextBlock Text="열기" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Rectangle Style="{StaticResource ToolSeparator}" />

                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding AddFilesCommand}"
                            ToolTip="압축할 파일 추가"
                            IsEnabled="{Binding IsArchiveMode, Converter={x:Static conv:NotBoolConverter.Instance}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconFileAdd}" Style="{StaticResource ToolIcon}" />
                            <TextBlock Text="파일 추가" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding AddFolderCommand}"
                            ToolTip="압축할 폴더 추가"
                            IsEnabled="{Binding IsArchiveMode, Converter={x:Static conv:NotBoolConverter.Instance}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconFolderAdd}" Style="{StaticResource ToolIcon}" />
                            <TextBlock Text="폴더 추가" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding CompressCommand}"
                            ToolTip="담은 항목을 압축 (Ctrl+N)"
                            IsEnabled="{Binding IsStagingMode}" Margin="3,0,1,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconArchive}" Width="17" Height="17" Stretch="Uniform"
                                  Fill="{DynamicResource AccentFgBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="압축 실행" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Rectangle Style="{StaticResource ToolSeparator}" />

                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ExtractCommand}"
                            ToolTip="압축 풀기 (Ctrl+E)"
                            IsEnabled="{Binding IsArchiveMode}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconExtract}" Style="{StaticResource ToolIcon}" />
                            <TextBlock Text="압축 풀기" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding ClearCommand}"
                            ToolTip="목록 비우기"
                            IsEnabled="{Binding HasAnyContent}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDelete}" Style="{StaticResource ToolIcon}" />
                            <TextBlock Text="비우기" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 우측: 보조 동작 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ThemeButton" Style="{StaticResource IconButton}" Click="Theme_Click" ToolTip="라이트/다크 전환">
                        <Path x:Name="ThemeIcon" Data="{StaticResource IconMoon}" Width="18" Height="18" Stretch="Uniform"
                              Fill="{DynamicResource FgMutedBrush}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Click="About_Click" ToolTip="일집 정보">
                        <Path Data="{StaticResource IconInfo}" Width="18" Height="18" Stretch="Uniform"
                              Fill="{DynamicResource FgMutedBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 본문 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 폴더 트리 (압축 파일을 열었을 때만 표시) -->
            <Border Grid.Column="0" Width="220"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                    Visibility="{Binding IsArchiveMode, Converter={x:Static conv:BoolToVisibility.Instance}}">
                <TreeView x:Name="FolderTreeView"
                          ItemsSource="{Binding FolderTree}"
                          SelectedItemChanged="FolderTree_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="15" Height="15" Stretch="Uniform"
                                      Fill="{DynamicResource FgMutedBrush}" VerticalAlignment="Center"
                                      Data="{StaticResource IconFolder}" />
                                <TextBlock Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <!-- 우측: 현재 폴더 목록 + 빈 상태 -->
            <Grid Grid.Column="1">
                <DataGrid x:Name="EntriesGrid"
                          ItemsSource="{Binding VisibleEntries}"
                          Margin="10,8"
                          PreviewKeyDown="EntriesGrid_PreviewKeyDown"
                          MouseDoubleClick="EntriesGrid_MouseDoubleClick"
                          Visibility="{Binding IsEmptyState, Converter={x:Static conv:InverseBoolToVisibility.Instance}}">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="선택 항목 압축 풀기" Click="ExtractSelected_Click" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="이름" Width="3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="15" Height="15" Stretch="Uniform"
                                              Fill="{DynamicResource FgMutedBrush}" VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Data" Value="{StaticResource IconFile}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Data" Value="{StaticResource IconFolder}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="크기"
                                            Binding="{Binding Size, Converter={StaticResource BytesToHuman}}"
                                            Width="110" />
                        <DataGridTextColumn x:Name="ColCompressed" Header="압축 크기"
                                            Binding="{Binding CompressedSize, Converter={StaticResource BytesToHuman}}"
                                            Width="110" />
                        <DataGridTextColumn x:Name="ColRatio" Header="압축률"
                                            Binding="{Binding CompressionRatio, StringFormat={}{0:F1}%}"
                                            Width="80" />
                        <DataGridTextColumn Header="수정한 날짜"
                                            Binding="{Binding LastModified, StringFormat=yyyy-MM-dd HH:mm}"
                                            Width="150" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 빈 상태 안내 (클릭 통과) -->
                <Border Visibility="{Binding IsEmptyState, Converter={x:Static conv:BoolToVisibility.Instance}}"
                        IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconBox}" Width="76" Height="76" Stretch="Uniform"
                              Fill="{DynamicResource FgMutedBrush}" Opacity="0.45"
                              HorizontalAlignment="Center" />
                        <TextBlock Text="압축 파일을 끌어다 놓으면 열려요"
                                   Margin="0,18,0,4" FontSize="14"
                                   Foreground="{DynamicResource FgBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="일반 파일·폴더를 놓으면 압축 목록에 담겨요"
                                   FontSize="13"
                                   Foreground="{DynamicResource FgMutedBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="담은 뒤 [압축 실행] 버튼을 눌러주세요"
                                   Margin="0,12,0,0" FontSize="12"
                                   Foreground="{DynamicResource FgMutedBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== 상태바 ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource StatusBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,5">
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource FgMutedBrush}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding CompressCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="E" Command="{Binding ExtractCommand}" />
    </Window.InputBindings>
</Window>
