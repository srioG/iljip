<Window x:Class="Iljip.Views.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="비밀번호 입력"
        Height="186" Width="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBgBrush}"
        TextElement.Foreground="{DynamicResource FgBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageText"
                   Grid.Row="0"
                   Text="이 압축 파일은 비밀번호가 필요해요."
                   Margin="0,0,0,10"
                   TextWrapping="Wrap" />

        <PasswordBox x:Name="PasswordBox1" Grid.Row="1" Height="28" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource DialogButton}" Content="확인" Width="84" Height="32" Click="Ok_Click" IsDefault="True" />
            <Button Style="{StaticResource DialogButton}" Content="취소" Width="84" Height="32" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
